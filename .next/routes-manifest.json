{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    },
    {
      "source": "/DesignCommercial",
      "destination": "/design/commercial",
      "statusCode": 308,
      "regex": "^(?!/_next)/DesignCommercial(?:/)?$"
    },
    {
      "source": "/DesignResidential",
      "destination": "/design/residential",
      "statusCode": 308,
      "regex": "^(?!/_next)/DesignResidential(?:/)?$"
    },
    {
      "source": "/contact/reviews",
      "destination": "/reviews",
      "statusCode": 308,
      "regex": "^(?!/_next)/contact/reviews(?:/)?$"
    },
    {
      "source": "/contact/testimonials",
      "destination": "/reviews",
      "statusCode": 308,
      "regex": "^(?!/_next)/contact/testimonials(?:/)?$"
    },
    {
      "source": "/design/commercial/galleries/:slug",
      "destination": "/design/commercial",
      "statusCode": 308,
      "regex": "^(?!/_next)/design/commercial/galleries(?:/([^/]+?))(?:/)?$"
    },
    {
      "source": "/design/residential/galleries/:slug",
      "destination": "/design/residential",
      "statusCode": 308,
      "regex": "^(?!/_next)/design/residential/galleries(?:/([^/]+?))(?:/)?$"
    },
    {
      "source": "/idea-center",
      "destination": "/design",
      "statusCode": 308,
      "regex": "^(?!/_next)/idea-center(?:/)?$"
    }
  ],
