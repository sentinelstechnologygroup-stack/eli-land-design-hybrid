  "dynamicRoutes": [
    {
      "page": "/design/commercial/galleries/[slug]",
      "regex": "^/design/commercial/galleries/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPslug": "nxtPslug"
      },
      "namedRegex": "^/design/commercial/galleries/(?<nxtPslug>[^/]+?)(?:/)?$"
    },
    {
      "page": "/design/commercial/[type]",
      "regex": "^/design/commercial/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPtype": "nxtPtype"
